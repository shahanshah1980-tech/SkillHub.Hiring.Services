<!DOCTYPE html>
<html>
<head>
<title>SkillHub Hiring Services</title>
<style>
body{font-family:Arial;background:#f2f2f2;text-align:center;margin-top:60px;}
.container{background:white;width:360px;margin:auto;padding:30px;border-radius:10px;box-shadow:0 0 10px #ccc;}
input{width:90%;padding:10px;margin:10px;font-size:16px;}
.btns{display:flex;justify-content:center;gap:10px;margin-top:10px;}
button{padding:10px 20px;font-size:16px;background:#0078d7;color:white;border:none;cursor:pointer;border-radius:5px;}
.signup{background:#0078d7;}
.back{background:#ff9800;}
.create{background:#0078d7;}
.cancel{background:#0078d7;}
.otp-container{display:flex;justify-content:center;gap:4px;margin-top:10px;display:none;}
.otp-box{width:22px;height:22px;font-size:14px;text-align:center;padding:0;}
#signupForm{display:none;}
</style>
</head>
<body>

<h1>SkillHub & Hiring Services</h1>

<div class="container" id="loginForm">
<h2>Login</h2>
<input type="text" id="username" placeholder="Username"><br>
<input type="password" id="password" placeholder="Password"><br>

<div class="otp-container" id="otpContainer">
<input class="otp-box" maxlength="1" disabled onkeyup="move(this,0)">
<input class="otp-box" maxlength="1" disabled onkeyup="move(this,1)">
<input class="otp-box" maxlength="1" disabled onkeyup="move(this,2)">
<input class="otp-box" maxlength="1" disabled onkeyup="move(this,3)">
<input class="otp-box" maxlength="1" disabled onkeyup="move(this,4)">
<input class="otp-box" maxlength="1" disabled onkeyup="move(this,5)">
</div>

<div class="btns">
<button onclick="login()">Login</button>
<button class="signup" onclick="openSignup()">Signup</button>
</div>
</div>

<div class="container" id="signupForm">
<h2>Create Account</h2>
<input type="text" id="fullName" placeholder="Full Name"><br>
<input type="text" id="mobile" placeholder="Mobile Number"><br>
<input type="text" id="newUsername" placeholder="Username"><br>
<input type="password" id="newPassword" placeholder="Password"><br>
<input type="password" id="confirmPassword" placeholder="Confirm Password"><br>
<div class="btns">
<button class="create" onclick="createAccount()">Create Account</button>
<button class="cancel" onclick="backLogin()">Cancel</button>
</div>
</div>

<script>
var otpEnabled=false;

function login(){
    var user=document.getElementById("username").value;
    var pass=document.getElementById("password").value;
    if(user==""||pass==""){ alert("Enter Username & Password"); return; }

    fetch("index.php",{method:"POST",headers:{"Content-Type":"application/x-www-form-urlencoded"},
    body:"action=login&username="+encodeURIComponent(user)+"&password="+encodeURIComponent(pass)})
    .then(res=>res.json()).then(data=>{
        if(data.status=="success"){
            alert("OTP sent via WhatsApp");
            document.getElementById("otpContainer").style.display="flex";
            otpEnabled=true;
            var boxes=document.getElementsByClassName("otp-box");
            for(var i=0;i<boxes.length;i++){ boxes[i].disabled=false; boxes[i].value=""; }
            boxes[0].focus();
        }else{ alert(data.message); }
    });
}

function move(field,index){
    if(!otpEnabled) return;
    var boxes=document.getElementsByClassName("otp-box");
    if(field.value.length==1 && index<5) boxes[index+1].focus();
    var entered=""; for(var i=0;i<6;i++) entered+=boxes[i].value;
    if(entered.length==6){
        var user=document.getElementById("username").value;
        fetch("index.php",{method:"POST",headers:{"Content-Type":"application/x-www-form-urlencoded"},
        body:"action=verify&username="+encodeURIComponent(user)+"&otp="+encodeURIComponent(entered)})
        .then(res=>res.json()).then(data=>{ if(data.status=="success"){ alert(data.message); window.location="dashboard.html"; } else{ alert(data.message); }});
    }
}

function openSignup(){ document.getElementById("loginForm").style.display="none"; document.getElementById("signupForm").style.display="block"; }
function backLogin(){ document.getElementById("signupForm").style.display="none"; document.getElementById("loginForm").style.display="block"; }

function createAccount(){
    var fullName=document.getElementById("fullName").value;
    var mobile=document.getElementById("mobile").value;
    var newUsername=document.getElementById("newUsername").value;
    var newPassword=document.getElementById("newPassword").value;
    var confirmPassword=document.getElementById("confirmPassword").value;
    if(fullName==""||mobile==""||newUsername==""||newPassword==""||confirmPassword==""){ alert("Fill all fields"); return; }
    if(newPassword!==confirmPassword){ alert("Passwords do not match"); return; }

    fetch("index.php",{method:"POST",headers:{"Content-Type":"application/x-www-form-urlencoded"},
    body:"action=signup&fullName="+encodeURIComponent(fullName)+"&mobile="+encodeURIComponent(mobile)+"&username="+encodeURIComponent(newUsername)+"&password="+encodeURIComponent(newPassword)})
    .then(res=>res.json()).then(data=>{ if(data.status=="success"){ alert(data.message); backLogin(); }else{ alert(data.message); }});
}
</script>

</body>
</html>
